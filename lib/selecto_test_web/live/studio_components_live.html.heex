<div class="mb-4 rounded-lg border border-emerald-200 bg-emerald-50 p-4">
  <h2 class="text-base font-semibold text-emerald-900">Studio Components Preview</h2>
  <p class="text-sm text-emerald-800">
    This view is generated from your Studio join config and opens in SelectoComponents with aggregate + detail views.
  </p>

  <.link
    navigate={~p"/studio"}
    class="mt-3 inline-flex rounded border border-emerald-300 bg-white px-3 py-1 text-xs font-semibold text-emerald-800 hover:bg-emerald-100"
  >
    Back to Studio
  </.link>
</div>

<.live_component
  module={SelectoComponents.Form}
  id="config"
  view_config={@view_config}
  selecto={@selecto}
  executed={@executed}
  applied_view={nil}
  active_tab={@active_tab}
  views={@views}
  saved_view_module={@saved_view_module}
  saved_view_context={@saved_view_context}
/>

<.live_component
  module={SelectoComponents.Results}
  selecto={@selecto}
  query_results={@query_results}
  applied_view={@applied_view}
  executed={@executed}
  execution_error={Map.get(assigns, :execution_error)}
  component_errors={Map.get(assigns, :component_errors, [])}
  views={@views}
  view_meta={@view_meta}
  domain_module={@saved_view_module}
  last_query_info={Map.get(assigns, :last_query_info, %{})}
  params={%{"selecto_debug" => "true"}}
  id="results"
/>
