<div class="mb-4 rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h2 class="text-base font-semibold text-gray-900">Saved Views</h2>
      <p class="text-sm text-gray-500">
        Load, rename, or delete saved views for this page.
      </p>
    </div>

    <div class="flex flex-wrap items-center gap-2">
      <.button phx-click="saved_views_refresh">Refresh Saved Views</.button>
      <.button phx-click="toggle_show_view_configurator">Toggle View Controller</.button>
    </div>
  </div>

  <%= if Enum.empty?(@available_saved_views) do %>
    <div class="mt-3 rounded-md border border-dashed border-gray-300 bg-gray-50 px-3 py-2 text-sm text-gray-500">
      No saved views yet. Save one from the "Save View" tab.
    </div>
  <% else %>
    <% current_saved_view = Map.get(Map.get(assigns, :params, %{}), "saved_view") %>
    <ul class="mt-3 space-y-2">
      <li
        :for={view <- @available_saved_views}
        class="rounded-md border border-gray-200 bg-gray-50 px-3 py-2"
      >
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <.link
              patch={saved_view_link(@path, Map.get(assigns, :params, %{}), view.name)}
              class={[
                "font-medium underline-offset-2 hover:underline",
                if(current_saved_view == view.name, do: "text-indigo-700", else: "text-gray-800")
              ]}
            >
              {view.name}
            </.link>

            <div class="text-xs text-gray-500">
              Updated {saved_view_updated_label(view.updated_at)}
            </div>
          </div>

          <div class="flex items-center gap-2">
            <button
              :if={@can_rename_saved_views}
              type="button"
              phx-click="saved_view_begin_rename"
              phx-value-name={view.name}
              class="rounded border border-gray-300 bg-white px-2 py-1 text-xs font-medium text-gray-700 hover:bg-gray-100"
            >
              Rename
            </button>

            <button
              :if={@can_delete_saved_views}
              type="button"
              phx-click="saved_view_delete"
              phx-value-name={view.name}
              data-confirm={"Delete saved view '#{view.name}'?"}
              class="rounded border border-red-300 bg-white px-2 py-1 text-xs font-medium text-red-700 hover:bg-red-50"
            >
              Delete
            </button>
          </div>
        </div>

        <form
          :if={@saved_view_rename_target == view.name}
          phx-submit="saved_view_rename"
          class="mt-2 flex flex-col gap-2 sm:flex-row sm:items-center"
        >
          <input type="hidden" name="old_name" value={view.name} />
          <input
            type="text"
            name="new_name"
            value={view.name}
            class="input input-bordered input-sm w-full sm:w-72"
            placeholder="New saved view name"
          />

          <div class="flex items-center gap-2">
            <button
              type="submit"
              class="rounded bg-indigo-600 px-3 py-1 text-xs font-semibold text-white hover:bg-indigo-700"
            >
              Save Rename
            </button>

            <button
              type="button"
              phx-click="saved_view_cancel_rename"
              class="rounded border border-gray-300 bg-white px-3 py-1 text-xs font-medium text-gray-700 hover:bg-gray-100"
            >
              Cancel
            </button>
          </div>
        </form>
      </li>
    </ul>
  <% end %>
</div>

<div :if={@show_view_configurator}>
  <.live_component
    module={SelectoComponents.Form}
    id="config"
    view_config={@view_config}
    selecto={@selecto}
    executed={@executed}
    applied_view={nil}
    active_tab={@active_tab}
    views={@views}
    saved_view_module={@saved_view_module}
    saved_view_context={@saved_view_context}
    saved_view_config_module={@saved_view_config_module}
    current_user_id={@current_user_id}
    domain_module={@saved_view_module}
    filter_sets_adapter={@filter_sets_adapter}
    user_id={@user_id}
    domain={@domain}
    path={@path}
  />
</div>

<%= if Map.get(assigns, :execution_error) && !Map.get(assigns, :applied_view) do %>
  <div
    class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded relative mb-4"
    role="alert"
  >
    <strong class="font-bold">View Error:</strong>
    <span class="block sm:inline ml-1">
      <%= case @execution_error do %>
        <% %{message: msg} -> %>
          {msg}
        <% error when is_binary(error) -> %>
          {error}
        <% error -> %>
          {inspect(error)}
      <% end %>
    </span>
  </div>
<% end %>

<%= if match?([_ | _], Map.get(assigns, :component_errors, [])) && !Map.get(assigns, :applied_view) do %>
  <div
    class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded relative mb-4"
    role="alert"
  >
    <strong class="font-bold">View Error:</strong>
    <span class="block sm:inline ml-1">
      Saved view could not be applied. Open the View Controller and resubmit after adjusting fields.
    </span>
  </div>
<% end %>

<.live_component
  module={SelectoComponents.Results}
  selecto={@selecto}
  query_results={@query_results}
  applied_view={@applied_view}
  executed={@executed}
  execution_error={Map.get(assigns, :execution_error)}
  component_errors={Map.get(assigns, :component_errors, [])}
  views={@views}
  view_meta={@view_meta}
  domain_module={@saved_view_module}
  last_query_info={Map.get(assigns, :last_query_info, %{})}
  params={%{"selecto_debug" => "true"}}
  id="results"
/>

<%!-- Modal Detail View (optional feature) --%>
<%= if Map.get(assigns, :show_detail_modal, false) && Map.get(assigns, :modal_detail_data) do %>
  <.live_component
    module={SelectoComponents.Modal.DetailModal}
    id="detail-modal"
    record={@modal_detail_data.record}
    current_index={@modal_detail_data.current_index}
    total_records={@modal_detail_data.total_records}
    records={@modal_detail_data.records}
    fields={@modal_detail_data.fields}
    related_data={Map.get(@modal_detail_data, :related_data, %{})}
    title="Record Details"
    size={:lg}
    navigation_enabled={true}
    edit_enabled={false}
    icon={nil}
    subtitle_field={nil}
  />
<% end %>
